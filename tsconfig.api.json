{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "rootDir": ".",
    "outDir": ".",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020"
  },
  "include": ["api/**/*.ts", "lib/**/*.ts"],
  "exclude": ["src", "node_modules", "dist"]
}
